# Copy to .env and load it before `dart_frog dev` (PowerShell example shown in README).

# JWT secret for admin sessions (use a long random string in production)
JWT_SECRET=please-change-me-to-a-long-random-string

# Default admin login (change for production)
ADMIN_EMAIL=admin@wedding.com
ADMIN_PASSWORD=wedding2026

# Couple info (optional — used in WhatsApp reminder text)
COUPLE_BRIDE=Pooja
COUPLE_GROOM=Arjun

# Public site URL (optional — used to build invite links in reminders)
SITE_URL=http://localhost:8080

# --- Firestore (optional) ---
# If both are set, the backend persists to Firestore via the REST API.
# Otherwise an in-memory store is used (great for development).
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_API_KEY=your-firebase-web-api-key
